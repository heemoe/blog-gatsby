---
import type { CollectionEntry } from 'astro:content';
import { getExcerpt, getPostUrl } from '../lib/content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const excerpt = getExcerpt(post);
const date = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <p class="post-card__date">{date}</p>
  <h2 class="post-card__title">
    <a href={getPostUrl(post)}>{post.data.title}</a>
  </h2>
  <p class="post-card__excerpt">{excerpt}</p>

  {
    post.data.tags.length > 0 && (
      <ul class="post-card__tags" aria-label="Tags">
        {post.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )
  }
</article>
